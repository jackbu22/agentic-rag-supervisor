# ══════════════════════════════════════════════
# .env.example — 이 파일을 복사해서 .env 로 만들고
# 각자 발급받은 API 키를 입력하세요
# cp .env.example .env
# ══════════════════════════════════════════════

# OpenAI API 키 (필수)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Tavily 웹 검색 API 키 (필수)
# https://tavily.com → 무료 1,000회/월
TAVILY_API_KEY=your-tavily-api-key-here

# LangSmith 트레이싱 (선택 — 워크플로우 시각화)
# https://smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Agentic_RAG_Supervisor

# HuggingFace 토큰 (선택 — bge-m3 모델 다운로드 가속)
HUGGINGFACEHUB_API_TOKEN=your-hf-token-here
